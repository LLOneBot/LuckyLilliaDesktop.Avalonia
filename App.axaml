<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:LuckyLilliaDesktop.Converters"
             x:Class="LuckyLilliaDesktop.App"
             RequestedThemeVariant="Default">
    <Application.Resources>
        <ResourceDictionary>
            <converters:EqualToIntConverter x:Key="EqualToIntConverter"/>
            <ResourceDictionary.ThemeDictionaries>
                <!-- 深色主题 -->
                <ResourceDictionary x:Key="Dark">
                    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#ec4899"/>
                        <GradientStop Offset="1" Color="#f472b6"/>
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="PrimaryBrush">#ec4899</SolidColorBrush>
                    <SolidColorBrush x:Key="PrimaryBrushSoft">#3A2131</SolidColorBrush>
                    <SolidColorBrush x:Key="PrimarySelectionBrush" Color="#F472B6" Opacity="0.72"/>
                    <SolidColorBrush x:Key="SidebarBackground">#0b1220</SolidColorBrush>
                    <SolidColorBrush x:Key="MainBackground">#090b17</SolidColorBrush>
                    <SolidColorBrush x:Key="CardBackground">#111827</SolidColorBrush>
                    <SolidColorBrush x:Key="CardBackgroundStrong">#281C2B</SolidColorBrush>
                    <SolidColorBrush x:Key="CardBackgroundSecondary">#151d33</SolidColorBrush>
                    <SolidColorBrush x:Key="TextPrimary">#f8fafc</SolidColorBrush>
                    <SolidColorBrush x:Key="TextSecondary">#cbd5e1</SolidColorBrush>
                    <SolidColorBrush x:Key="BorderColor">#23314e</SolidColorBrush>
                    <SolidColorBrush x:Key="HoverBackground">#342131</SolidColorBrush>
                    <SolidColorBrush x:Key="SelectedBackground">#3A2131</SolidColorBrush>
                    <SolidColorBrush x:Key="SuccessColor">#22c55e</SolidColorBrush>
                    <SolidColorBrush x:Key="DangerColor">#fb7185</SolidColorBrush>
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#F472B6"/>
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#F472B6"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="#F472B6"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeChecked" Color="#F472B6"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" Color="#EC5FAA"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPointerOver" Color="#EC5FAA"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPressed" Color="#DB4C99"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPressed" Color="#DB4C99"/>
                </ResourceDictionary>
                <!-- 浅色主题 -->
                <ResourceDictionary x:Key="Light">
                    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#fb7185"/>
                        <GradientStop Offset="1" Color="#f97316"/>
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="PrimaryBrush">#f43f5e</SolidColorBrush>
                    <SolidColorBrush x:Key="PrimaryBrushSoft">#FFF0F8</SolidColorBrush>
                    <SolidColorBrush x:Key="PrimarySelectionBrush" Color="#E84D9C" Opacity="0.72"/>
                    <SolidColorBrush x:Key="SidebarBackground">#f8fafc</SolidColorBrush>
                    <SolidColorBrush x:Key="MainBackground">#f8fafc</SolidColorBrush>
                    <SolidColorBrush x:Key="CardBackground">#ffffff</SolidColorBrush>
                    <SolidColorBrush x:Key="CardBackgroundStrong">#FFFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardBackgroundSecondary">#f1f5f9</SolidColorBrush>
                    <SolidColorBrush x:Key="TextPrimary">#0f172a</SolidColorBrush>
                    <SolidColorBrush x:Key="TextSecondary">#475569</SolidColorBrush>
                    <SolidColorBrush x:Key="BorderColor">#e2e8f0</SolidColorBrush>
                    <SolidColorBrush x:Key="HoverBackground">#FFF0F8</SolidColorBrush>
                    <SolidColorBrush x:Key="SelectedBackground">#FFF0F8</SolidColorBrush>
                    <SolidColorBrush x:Key="SuccessColor">#16a34a</SolidColorBrush>
                    <SolidColorBrush x:Key="DangerColor">#dc2626</SolidColorBrush>
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#E84D9C"/>
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#E84D9C"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="#E84D9C"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeChecked" Color="#E84D9C"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" Color="#D83E8D"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPointerOver" Color="#D83E8D"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPressed" Color="#C93482"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPressed" Color="#C93482"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/Styles/AppStyles.axaml"/>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei,Segoe UI Emoji"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="FontFamily" Value="Microsoft YaHei,Segoe UI Emoji"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="FontFamily" Value="Microsoft YaHei,Segoe UI Emoji"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="FontFamily" Value="Microsoft YaHei,Segoe UI Emoji"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="FontFamily" Value="Microsoft YaHei,Segoe UI Emoji"/>
        </Style>
        <Style Selector="ComboBox /template/ Border#PART_PopupBorder">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        </Style>
        <Style Selector="ComboBox /template/ Border#PopupBorder">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ComboBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SelectedBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SelectedBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontFamily" Value="Microsoft YaHei,Segoe UI Emoji"/>
        </Style>
    </Application.Styles>
    
    <!-- 托盘图标 -->
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="avares://LuckyLilliaDesktop/Assets/Icons/icon.ico"
                      ToolTipText="LLBot" 
                      Clicked="TrayIcon_Clicked">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="显示主窗口" Click="ShowWindow_Click"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="退出" Click="Exit_Click"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
