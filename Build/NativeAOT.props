<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup Label="PublishConfiguration" Condition="'$(Configuration)' == 'Release'">
    <PublishAot>true</PublishAot>
  </PropertyGroup>

  <PropertyGroup Label="PublishAotConfiguration" Condition="'$(PublishAot)' == 'true'">
    <TrimMode>full</TrimMode>
    <BuiltInComInteropSupport>false</BuiltInComInteropSupport>
    <StaticExecutable Condition="'$(RuntimeIdentifier)' == 'win-x64'">true</StaticExecutable>
    <IlcGenerateStackTraceData>false</IlcGenerateStackTraceData>
    <DebuggerSupport>false</DebuggerSupport>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <StripSymbols>true</StripSymbols>
    <StackTraceSupport>false</StackTraceSupport>
  </PropertyGroup>

  <PropertyGroup Condition="'$(PublishAot)' == 'true'">
    <_2ndLabSkiaSharpStaticRoot>$(NuGetPackageRoot)2ndlab.skiasharp.static/$(SkiaSharpStaticPackageVersion)</_2ndLabSkiaSharpStaticRoot>
    <_2ndLabANGLEStaticRoot>$(NuGetPackageRoot)2ndlab.angle.static/$(ANGLEStaticPackageVersion)</_2ndLabANGLEStaticRoot>
  </PropertyGroup>

  <ItemGroup Condition="'$(PublishAot)' == 'true' and '$(RuntimeIdentifier)' == 'win-x64'">
    <DirectPInvoke Include="libHarfBuzzSharp" />
    <DirectPInvoke Include="libSkiaSharp" />
    <DirectPInvoke Include="av_libglesv2" />
    <NativeLibrary Include="$(_2ndLabSkiaSharpStaticRoot)/runtimes/win-x64/native/libHarfBuzzSharp.lib" />
    <NativeLibrary Include="$(_2ndLabSkiaSharpStaticRoot)/runtimes/win-x64/native/skia.lib" />
    <NativeLibrary Include="$(_2ndLabSkiaSharpStaticRoot)/runtimes/win-x64/native/SkiaSharp.lib" />
    <NativeLibrary Include="$(_2ndLabANGLEStaticRoot)/runtimes/win-x64/native/libANGLE_static.lib" />
    <NativeLibrary Include="$(_2ndLabANGLEStaticRoot)/runtimes/win-x64/native/libGLESv2_static.lib" />
    <LinkerArg Include="d3d9.lib;dxguid.lib" />
    <LinkerArg Include="dxgi.lib" />
    <LinkerArg Include="Gdi32.lib;User32.lib" />
    <LinkerArg Include="synchronization.lib" />
    <LinkerArg Include="fontsub.lib;Ole32.lib;USP10.lib" />
    <LinkerArg Include="d3d12.lib;d3dcompiler.lib" />
    <LinkerArg Include="/LTCG" />
  </ItemGroup>

  <Target Name="CleanupNativeAotPublishArtifacts" AfterTargets="Publish" Condition="'$(PublishAot)' == 'true' and '$(RuntimeIdentifier)' == 'win-x64'">
    <PropertyGroup>
      <_NativeAotPublishDir>$([MSBuild]::EnsureTrailingSlash('$(PublishDir)'))</_NativeAotPublishDir>
    </PropertyGroup>
    <ItemGroup>
      <FilesToDelete Include="$(_NativeAotPublishDir)*.pdb" />
      <FilesToDelete Include="$(_NativeAotPublishDir)*.lib" />
      <FilesToDelete Include="$(_NativeAotPublishDir)av_libglesv2.dll" />
      <FilesToDelete Include="$(_NativeAotPublishDir)libHarfBuzzSharp.dll" />
      <FilesToDelete Include="$(_NativeAotPublishDir)libSkiaSharp.dll" />
    </ItemGroup>

    <Delete Files="@(FilesToDelete)" TreatErrorsAsWarnings="true" />
  </Target>

</Project>
