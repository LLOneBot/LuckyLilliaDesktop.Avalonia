<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LuckyLilliaDesktop.Views.AuthTokenDialog"
        Title=""
        Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

    <Border CornerRadius="12"
            Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
            Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="请输入 Auth Token"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="启动 LLBot 需要 Auth Token。如果还没有，请点击下方链接获取："
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondary}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>

            <TextBlock x:Name="LinkText"
                       Text="https://s.luckylillia.com"
                       FontSize="14"
                       Foreground="{DynamicResource PrimaryBrush}"
                       TextDecorations="Underline"
                       Cursor="Hand"
                       HorizontalAlignment="Center"
                       PointerPressed="OnLinkClick"/>

            <TextBox x:Name="InputBox"
                     Watermark="在此粘贴 Auth Token"
                     FontSize="14"
                     Padding="10,8"/>

            <TextBlock x:Name="ErrorText"
                       Text=""
                       IsVisible="False"
                       FontSize="12"
                       Foreground="{DynamicResource DangerColor}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>

            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Center">
                <Button x:Name="OkButton"
                        Content="确定"
                        Width="100"
                        Padding="0,10"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="White"
                        HorizontalContentAlignment="Center"
                        Click="OnOkClick"/>
                <Button x:Name="CancelButton"
                        Content="取消"
                        Width="100"
                        Padding="0,10"
                        HorizontalContentAlignment="Center"
                        Click="OnCancelClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
